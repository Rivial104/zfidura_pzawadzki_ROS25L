<?xml version="1.0" ?>
<robot name="my_manipulator">

  <!-- Colors -->
  <material name="Yellow">
    <color rgba="1.0 1.0 0.0 1.0"/>
  </material>
  <material name="Blue">
  <color rgba="0.0 0.0 1.0 1.0"/>      
  </material>
  <material name="Red">
    <color rgba="1 0 0 1.0"/>      
  </material>
    <material name="Pink">
    <color rgba="1 0.3 0.6 1.0"/>      
  </material>


  <link name="Base">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry>
        <cylinder radius = "0.8" length = "0.1" />
      </geometry>
      <material name="Yellow"/>
    </visual>
  </link>

  <joint name="Joint_1" type="revolute">
    <parent link="Base"/>
    <child link="Link_1"/>
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.1415" upper="3.1415" velocity="0.5" />
  </joint>


  <link name="Link_1">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.4"/>
      <geometry>
        <cylinder radius = "0.15" length = "0.8" />
      </geometry>
      <material name="Blue"/>
    </visual>
  </link>

  <joint name="Joint_2" type="revolute">
    <parent link="Link_1"/>
    <child link="Link_2"/>
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000.0" lower="-0.785" upper="0.785" velocity="0.5" />
  </joint>


  <link name="Link_2">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.4"/>
      <geometry>
        <cylinder radius = "0.15" length = "0.8" />
      </geometry>
      <material name="Red"/>
    </visual>
  </link>

  <joint name="Joint_3" type="revolute">
    <parent link="Link_2"/>
    <child link="Link_3"/>
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000.0" lower="-0.785" upper="0.785" velocity="0.5" />
  </joint>


  <link name="Link_3">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.4"/>
      <geometry>
        <cylinder radius = "0.15" length = "0.8" />
      </geometry>
      <material name="Yellow"/>
      
    </visual>
  </link>

  <joint name="tool_nul" type="fixed">
    <parent link="Link_3"/>
    <child link="Tool"/>
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
  </joint>


  <link name="Tool">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
    </visual>
  </link>


</robot>